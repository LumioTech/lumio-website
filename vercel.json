{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "rewrites": [
    { "source": "/storelocationscore", "destination": "/bm-19-storelocationscore/index.html" }
  ],
  "redirects": [
    { "source": "/services", "permanent": true, "destination": "/what-we-do" }
  ]
}
